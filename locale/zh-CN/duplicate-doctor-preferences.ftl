duplicate-doctor-pref-action-title = 默认操作设置
duplicate-doctor-pref-default-action-description = 处理重复条目的默认操作
duplicate-doctor-pref-default-action-keep-this =
    .label = [保留最新的] 以新导入条目为主条目，合并重复条目
duplicate-doctor-pref-default-action-keep-others =
    .label = [保留已有的] 以已有条目为主条目，合并重复条目
duplicate-doctor-pref-default-action-keep-all =
    .label = [保留全部] 保留所有条目，不合并任何项
duplicate-doctor-pref-default-action-always-ask =
    .label = [始终询问] 每次都询问我该如何处理

duplicate-doctor-pref-auto-title = 导入时增强去重
duplicate-doctor-pref-auto-description = Duplicate Doctor 额外支持导入时按 DOI/ISBN 直接丢弃新导入重复项。
duplicate-doctor-pref-auto-discard =
    .label = 启用自动丢弃新导入重复项
duplicate-doctor-pref-doi =
    .label = 使用 DOI 判断重复
duplicate-doctor-pref-isbn =
    .label = 使用 ISBN 判断重复
duplicate-doctor-pref-trash-children =
    .label = 丢弃重复条目时同时移动其附件和笔记到回收站
duplicate-doctor-pref-notifications =
    .label = 发现重复并丢弃时显示提示

duplicate-doctor-pref-master-title = 主条目设置
duplicate-doctor-pref-master-description = 选择作为主条目的条目版本
duplicate-doctor-pref-master-oldest =
    .label = [最早添加的] 根据添加日期选择最早的条目
duplicate-doctor-pref-master-newest =
    .label = [最新添加的] 根据添加日期选择最新的条目
duplicate-doctor-pref-master-modified =
    .label = [最近修改的] 根据修改日期选择最近的条目
duplicate-doctor-pref-master-detailed =
    .label = [最详细的] 选择字段、附件、标签和分类更多的条目

duplicate-doctor-pref-view-title = 视图设置
duplicate-doctor-pref-view-description = 选择重复条目的显示方式
duplicate-doctor-pref-view-duplicate-stats =
    .label = 在“重复条目”标签后显示重复条目数量。如，重复条目 2/6

duplicate-doctor-pref-merge-title = 手动合并设置
duplicate-doctor-pref-merge-webpage =
    .label = 允许安全合并同 DOI 网页项到期刊文章
duplicate-doctor-pref-safety-note = 批量合并会先使用 Zotero 的重复项集合；同 DOI 网页项会尝试安全并入期刊文章；仅标题相同的条目不会自动丢弃。

duplicate-doctor-pref-data-title = 数据管理
duplicate-doctor-pref-data-description = 导出或导入“非重复”标记记录，用于跨设备迁移。
duplicate-doctor-pref-data-export =
    .label = 导出非重复记录…
duplicate-doctor-pref-data-import =
    .label = 导入非重复记录…
duplicate-doctor-pref-help = Duplicate Doctor Build 0.2.0
