duplicate-doctor-pref-action-title = Default Action
duplicate-doctor-pref-default-action-description = Default action for newly detected duplicate items
duplicate-doctor-pref-default-action-keep-this =
    .label = [Keep newest] Use the newly imported item as master and merge duplicate items
duplicate-doctor-pref-default-action-keep-others =
    .label = [Keep existing] Use the existing item as master and merge duplicate items
duplicate-doctor-pref-default-action-keep-all =
    .label = [Keep all] Keep all items and merge nothing
duplicate-doctor-pref-default-action-always-ask =
    .label = [Always ask] Ask me what to do each time

duplicate-doctor-pref-auto-title = Enhanced Import Deduplication
duplicate-doctor-pref-auto-description = Duplicate Doctor can additionally discard newly imported DOI/ISBN duplicates immediately.
duplicate-doctor-pref-auto-discard =
    .label = Enable auto-discard for newly imported duplicates
duplicate-doctor-pref-doi =
    .label = Match duplicates by DOI
duplicate-doctor-pref-isbn =
    .label = Match duplicates by ISBN
duplicate-doctor-pref-trash-children =
    .label = Move attachments and notes of discarded duplicates to the trash
duplicate-doctor-pref-notifications =
    .label = Show a notification when duplicates are discarded

duplicate-doctor-pref-master-title = Master Item
duplicate-doctor-pref-master-description = Choose which item version is kept as the master item
duplicate-doctor-pref-master-oldest =
    .label = [Oldest added] Keep the item with the earliest date added
duplicate-doctor-pref-master-newest =
    .label = [Newest added] Keep the item with the latest date added
duplicate-doctor-pref-master-modified =
    .label = [Recently modified] Keep the most recently modified item
duplicate-doctor-pref-master-detailed =
    .label = [Most detailed] Keep the item with more fields, attachments, tags, and collections

duplicate-doctor-pref-view-title = View
duplicate-doctor-pref-view-description = Choose how duplicate items are displayed
duplicate-doctor-pref-view-duplicate-stats =
    .label = Show duplicate counts after the “Duplicate Items” label, e.g. Duplicate Items 2/6

duplicate-doctor-pref-merge-title = Manual Merge
duplicate-doctor-pref-merge-webpage =
    .label = Allow safe same-DOI webpage merges into journal articles
duplicate-doctor-pref-safety-note = Bulk merge uses Zotero duplicate sets first; same-DOI webpages are safely merged into journal articles; same-title-only items are never discarded automatically.

duplicate-doctor-pref-data-title = Data
duplicate-doctor-pref-data-description = Export or import “non-duplicate” marker records for migration across devices.
duplicate-doctor-pref-data-export =
    .label = Export non-duplicate records…
duplicate-doctor-pref-data-import =
    .label = Import non-duplicate records…
duplicate-doctor-pref-help = Duplicate Doctor Build 0.2.0
